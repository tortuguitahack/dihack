# .env.example

PORT=8000
JARVIZ_URL=http://localhost:8000
GRAFANA_URL=http://localhost:3000

# Embeddings: 'sentence-transformers' or 'ollama'
EMBEDDING_BACKEND=sentence-transformers
EMBEDDING_URL=http://localhost:9000/embed

# Ollama local URL and preferred models (comma separated)
OLLAMA_URL=http://localhost:11434
OLLAMA_PREFERRED_MODELS=.hermes,.codex,.antigravity
OLLAMA_EMBEDDING_MODEL=

# Postgres (pgvector) DSN (optional for future integration)
PGVECTOR_DSN=postgresql://postgres:postgres@localhost:5432/jarviz
